DATA_DIR=data

# PARSER
PARSER_HOURS=2
RSS_TIMEOUT=20
RSS_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 TrendWatcher/1.0
RSS_FALLBACK_WITHOUT_SSL_VERIFY=1

TG_API_ID=
TG_API_HASH=


# OPENROUTER
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=TrendWatcher


# MODELS
FILTER_MODEL=openai/gpt-4o-mini

# Карточки: качество/цена
# Дешево: openai/gpt-4o-mini
# Лучше: google/gemini-2.5-flash
# Дорого: anthropic/claude-sonnet-4-5
CARD_MODEL=google/gemini-2.5-flash

# Эмбеддинги для дедупликации
EMBEDDING_MODEL=openai/text-embedding-3-small


# LLM RUNTIME
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_SECONDS=1
LLM_TIMEOUT=45
LLM_USER_TEXT_LIMIT=6000


# LLM FILTER
# 0 = экономим: используем локальный keyword/scoring фильтр
# 1 = используем LLM-фильтр после дедупликации
USE_LLM_FILTER=0
# Если keyword-фильтр не уверен, можно добивать LLM
FILTER_UNKNOWN_WITH_LLM=0
LLM_FILTER_KEYWORD_PREPASS=1
LLM_FILTER_KEYWORD_MIN_SCORE=2


# WORKERS
DEDUP_WORKERS=4
LLM_FILTER_WORKERS=1
MAKE_CARD_WORKERS=1


# DEDUPLICATION
DEDUP_USE_EMBEDDINGS=1
DEDUP_LEVEL_1_THRESHOLD=0.84
DEDUP_LEVEL_2_THRESHOLD=0.74
DEDUP_TEXT_JACCARD_THRESHOLD=0.18
DEDUP_TEXT_SEQUENCE_THRESHOLD=0.50
DEDUP_TITLE_SEQUENCE_THRESHOLD=0.40